--- !u!114 &95312845
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 95312844}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1d6b162fb1c3b764a9b640e44ebd8808, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  stages:
  - stageName: World1-PulauHening
    actTitle: "Pulau Hening \u2014 Awal Sang Penjaga"
    description: "Pulau Hening adalah tempat kelahiran Arka, desa kecil di pesisir
      Nusantara yang damai.\nNamun, angin membawa firasat aneh \u2014 alam seolah
      ingin berbicara.\n\nSebagai penerus Busur Leluhur, Arka memulai langkah pertamanya
      untuk memahami panggilan tersebut.\nDi sini, ia berlatih mengasah fokus dan
      ketepatan, mempelajari dasar-dasar kemampuan yang kelak menentukan nasib seluruh
      pulau.\n\nMisi:\nBantu Arka menyelesaikan latihan panah pertama dan buka gerbang
      perjalanan menuju dunia yang lebih luas."
    stageID: 1
    stageButton: {fileID: 2116146068}
    stageImage: {fileID: 2116146069}
    unlockedSprite: {fileID: 21300000, guid: b7d1c29ea2e65a54d97a0e131d905a5d, type: 3}
    lockedSprite: {fileID: 21300000, guid: e45f9ef5872bc5546b79759e93d76023, type: 3}
  - stageName: World2-PulauRimba
    actTitle: "Pulau Rimba \u2014 Bisikan Roh Hutan"
    description: "Setelah meninggalkan desa, Arka tiba di Pulau Rimba \u2014 hutan
      tropis yang padat dan dipenuhi misteri tua.\nKabut tipis menyelimuti pepohonan,
      dan suara roh alam bergaung di antara dedaunan.\n\nTotem Roh kuno di pulau
      ini mulai tidak stabil, seolah meminta bantuan.\nHanya mereka yang mampu membaca
      urutan cahaya dan keseimbangan yang dapat menenangkan pergerakan roh.\n\nMisi:\nPecahkan
      teka-teki Totem Roh dan buktikan bahwa Arka layak disebut Penjaga Alam."
    stageID: 2
    stageButton: {fileID: 1407379624}
    stageImage: {fileID: 1407379625}
    unlockedSprite: {fileID: 21300000, guid: b7d1c29ea2e65a54d97a0e131d905a5d, type: 3}
    lockedSprite: {fileID: 21300000, guid: e45f9ef5872bc5546b79759e93d76023, type: 3}
  - stageName: World3-PulauPenjaga
    actTitle: "Pulau Penjaga \u2014 Arca Terbangun"
    description: "Perjalanan Arka membawanya ke pulau terakhir \u2014 puncak batu
      kuno tempat para leluhur menyegel kekuatan besar.\nNamun segel itu kini melemah.\nObor-obor
      penjaga meredup, dan Arca raksasa yang selama ratusan tahun tertidur mulai
      terbangun.\n\nHanya Cahaya Leluhur yang dapat membuka jalan menuju arena suci\u2026
      dan hanya keberanian sejati yang dapat mengakhiri kekacauan yang akan bangkit.\n\nMisi:\nNyalakan
      empat obor batu menggunakan panah cahaya dan hadapi Arca Penjaga dalam pertarungan
      klimaks."
    stageID: 3
    stageButton: {fileID: 324736777}
    stageImage: {fileID: 324736778}
    unlockedSprite: {fileID: 21300000, guid: b7d1c29ea2e65a54d97a0e131d905a5d, type: 3}
    lockedSprite: {fileID: 21300000, guid: e45f9ef5872bc5546b79759e93d76023, type: 3}
  stageInfoPanel: {fileID: 1135396642}
  titleText: {fileID: 993670454}
  descText: {fileID: 1266143887}
  playButton: {fileID: 1488737147}
